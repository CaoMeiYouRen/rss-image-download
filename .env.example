# 百度网盘配置 (可通过横向登录 BaiduPCS-Go 获取)
BDUSS=your_bduss
STOKEN=your_stoken

# 备份路径 (网盘路径)
REMOTE_BACKUP_PATH=/apps/rss-image-download

# 任务频率 (Cron 表达式)
CRON_SCHEDULE=0 */15 * * * *
ARCHIVE_CRON=0 0 4 * * *

# 聚合备份触发阈值
# 文件数达到该值时触发打包备份
ARCHIVE_TRIGGER_MAX_FILES=1000
# 总大小达到该值时触发打包备份（使用 better-bytes 语法，例如 2GiB / 500MiB / 2GB）
ARCHIVE_TRIGGER_MAX_SIZE=2GiB
# 累计未备份日期达到该值时触发（兜底策略）
ARCHIVE_MAX_PENDING_DAYS=3
# 定时任务是否包含当天目录（建议 false，避免与下载并发冲突）
ARCHIVE_INCLUDE_TODAY=false

# 下载并发数
DOWNLOAD_CONCURRENCY=5

# 数据库存储路径 (相对于项目根目录或绝对路径)
DB_PATH=data/data.db

# 推送通知 (使用 push-all-in-one v4)
# 1. 如果使用本地直接推送：
PUSH_TYPE=Dingtalk
# 推荐写法（标准结构：config + option）
PUSH_CONFIG={"config":{"DINGTALK_ACCESS_TOKEN":"your_token","DINGTALK_SECRET":"your_secret"},"option":{"msgtype":"markdown"}}
# 兼容旧写法（仍可用）：
# PUSH_CONFIG={"DINGTALK_ACCESS_TOKEN":"your_token","DINGTALK_SECRET":"your_secret"}

# 2. 如果使用 push-all-in-cloud 云转发 (可选)：
PUSH_URL=https://your-push-cloud-url
PUSH_KEY=your-auth-token
